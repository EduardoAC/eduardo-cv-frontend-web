/service-worker.js
  Cache-Control: no-store, no-cache, must-revalidate
  CDN-Cache-Control: no-store
  Cloudflare-CDN-Cache-Control: no-store
  Service-Worker-Allowed: /

/theme-init.js
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/*.txt
  Cache-Control: public, max-age=0, must-revalidate

/manifest.webmanifest
  Cache-Control: public, max-age=0, must-revalidate

/robots.txt
  Cache-Control: public, max-age=0, must-revalidate

/sitemap*
  Cache-Control: public, max-age=0, must-revalidate

/_next/static/css/*
  Cache-Control: public, max-age=0, must-revalidate

/_next/static/chunks/*
  Cache-Control: public, max-age=0, must-revalidate

{
  "name": "eduardo-cv-frontend-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.12.0 <25"
  },
  "scripts": {
    "dev": "next dev",
    "predev": "node scripts/generate-site-image-manifest.js && node scripts/generate-blog-manifest.js",
    "prebuild": "node scripts/generate-site-image-manifest.js && node scripts/generate-blog-manifest.js && node scripts/validate-blog-content.js && node scripts/validate-image-delivery.js",
    "pretypecheck": "node scripts/generate-site-image-manifest.js && node scripts/generate-blog-manifest.js",
    "postbuild": "node scripts/generate-sw.js && node scripts/verify-blog-output.js",
    "build": "next build --webpack",
    "start": "next start",
    "serve": "serve dist -p 3000",
    "blog:validate": "node scripts/generate-blog-manifest.js && node scripts/validate-blog-content.js",
    "blog:verify": "node scripts/verify-blog-output.js",
    "blog:report": "node scripts/report-blog-benchmarks.js",
    "images:validate": "node scripts/generate-site-image-manifest.js && node scripts/validate-image-delivery.js",
    "images:audit": "node scripts/generate-site-image-manifest.js && node scripts/generate-image-audit-report.js",
    "lint": "eslint app components lib instrumentation.ts instrumentation-client.ts --max-warnings=0",
    "typecheck": "next typegen && tsc --noEmit",
    "analyze": "ANALYZE=true npm run build",
    "lighthouse": "lighthouse http://localhost:3000 --output=json --output-path=./lighthouse-report.json",
    "lighthouse:html": "lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-report.html",
    "performance": "npm run build && npm run lighthouse",
    "performance:all": "npm run build && npm run lighthouse && npm run lighthouse:html",
    "bundle-size": "npm run build && npx next-bundle-analyzer",
    "lost-pixel": "lost-pixel",
    "lost-pixel:update": "lost-pixel update",
    "worker:typecheck": "tsc -p workers/subscription-handler/tsconfig.json --noEmit",
    "worker:dev": "wrangler dev --config ./workers/subscription-handler/wrangler.toml --env stagee",
    "worker:deploy": "wrangler deploy --config ./workers/subscription-handler/wrangler.toml --env production",
    "generate-csp-hashes": "node scripts/generate-csp-hashes.ts"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.43.0",
    "@types/marked": "^5.0.2",
    "@types/prismjs": "^1.26.5",
    "gray-matter": "^4.0.3",
    "marked": "^16.0.0",
    "next": "^16.1.7",
    "prismjs": "^1.30.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^4.7.0",
    "sass": "^1.69.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260312.1",
    "@playwright/test": "1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.6",
    "lost-pixel": "^3.22.0",
    "serve": "^14.2.6",
    "sharp": "^0.34.2",
    "typescript": "^5.9.2",
    "wrangler": "^4.72.0"
  },
  "overrides": {
    "axios": "^1.13.6",
    "diff": "^4.0.4",
    "esbuild": "^0.27.4",
    "form-data": "^4.0.5",
    "playwright-core": "1.58.2",
    "rollup": "^4.59.0",
    "serve-handler": "^6.1.7",
    "gray-matter": {
      "js-yaml": "3.14.2"
    },
    "sass": {
      "immutable": "^5.1.5"
    }
  }
}
